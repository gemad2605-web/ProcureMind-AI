# ============================================
# ProcureMind-AI — نموذج متغيرات البيئة
# ============================================
# انسخي هذا الملف باسم .env واملئي القيم الفعلية
# cp .env.example .env

# ----------- إعدادات التطبيق العامة -----------
APP_ENV=development
APP_NAME=ProcureMind-AI
APP_DEBUG=true
APP_PORT=8000

# ----------- إعدادات الـ LLM (Grok) -----------
GROK_API_KEY=
GROK_MODEL=grok-2-latest
GROK_API_BASE_URL=https://api.x.ai/v1

# ----------- إعدادات RAG -----------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
EMBEDDING_MODEL=text-embedding-3-small

# ----------- مسارات الفهرس والبيانات -----------
FAISS_INDEX_PATH=faiss_index/index.faiss
KNOWLEDGE_BASE_PATH=knowledge_base
DATA_UPLOADS_PATH=data/uploads

# ----------- إعدادات الفرونت إند (CORS) -----------
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# ----------- إعدادات التسجيل (Logging) -----------
LOG_LEVEL=INFO
LOG_FILE_PATH=data/logs/app.log
