# ============================================================
# 🔑 ProcureMind-AI - Environment Variables
# ============================================================
# انسخ هذا الملف إلى .env وقم بتعبئة القيم المناسبة
# ⚠️ لا ترفع ملف .env على GitHub أبداً!
# ============================================================

# ============================================================
# 🔑 مفاتيح API
# ============================================================

# Grok API (xAI) - مطلوب لتشغيل النموذج اللغوي
# احصل على المفتاح من: https://x.ai
GROK_API_KEY = "your_grok_api_key_here"
GROK_MODEL = "grok-1"
GROK_API_URL = "https://api.x.ai/v1/chat/completions"

# OpenAI API (اختياري - احتياطي)
# احصل على المفتاح من: https://platform.openai.com
OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-4"
OPENAI_API_URL = "https://api.openai.com/v1/chat/completions"

# ============================================================
# 📁 مسارات الملفات
# ============================================================

# مجلد المستندات (ضع ملفاتك هنا)
KNOWLEDGE_BASE_PATH = "./knowledge_base"

# مجلد فهرس FAISS
FAISS_INDEX_PATH = "./faiss_index"

# مجلد البيانات (التخزين المؤقت، السجلات، الخ)
DATA_PATH = "./data"

# مجلد السجلات
LOGS_PATH = "./logs"

# ============================================================
# 🧬 إعدادات المتجهات (Embeddings)
# ============================================================

# النموذج المستخدم لتوليد المتجهات
# خيارات: paraphrase-multilingual-MiniLM-L12-v2, all-MiniLM-L6-v2, all-mpnet-base-v2
EMBEDDING_MODEL = "paraphrase-multilingual-MiniLM-L12-v2"

# الجهاز: cpu أو cuda (للـ GPU)
EMBEDDING_DEVICE = "cpu"

# حجم الدفعة لتوليد المتجهات
EMBEDDING_BATCH_SIZE = 32

# أبعاد المتجهات (يعتمد على النموذج)
EMBEDDING_DIMENSION = 384

# ============================================================
# 📊 إعدادات RAG
# ============================================================

# عدد النتائج المسترجعة من FAISS
DEFAULT_TOP_K = 10

# الحد الأقصى لعدد المصادر في الرد
DEFAULT_MAX_SOURCES = 5

# درجة الإبداع في الرد (0.0 - 1.0)
DEFAULT_TEMPERATURE = 0.7

# الحد الأدنى لدرجة الثقة (0.0 - 1.0)
MIN_CONFIDENCE_SCORE = 0.3

# حجم القطعة النصية (عدد الكلمات)
CHUNK_SIZE = 500

# عدد الكلمات المتداخلة بين القطع
CHUNK_OVERLAP = 50

# الحد الأدنى لحجم القطعة
MIN_CHUNK_SIZE = 50

# ============================================================
# 🗄️ إعدادات قاعدة البيانات
# ============================================================

# PostgreSQL (اختياري - للتخزين الدائم)
# DATABASE_URL = "postgresql://user:password@localhost:5432/procuremind"

# حجم تجمع الاتصالات
DATABASE_POOL_SIZE = 5
DATABASE_MAX_OVERFLOW = 10

# Redis (اختياري - للتخزين المؤقت)
REDIS_URL = "redis://localhost:6379"
REDIS_CACHE_TTL = 3600  # ثانية

# ============================================================
# 🖥️ إعدادات الخادم
# ============================================================

# اسم التطبيق
APP_NAME = "ProcureMind-AI"

# إصدار التطبيق
APP_VERSION = "1.0.0"

# بيئة التشغيل: development, testing, production
ENVIRONMENT = "development"

# وضع التصحيح (True/False)
DEBUG = True

# مفتاح سري للتطبيق (غيّره في الإنتاج!)
SECRET_KEY = "your-secret-key-change-this-in-production"

# إعدادات الخادم
API_HOST = "0.0.0.0"
API_PORT = 8000
API_PREFIX = "/api"

# CORS - السماح بالوصول من هذه العناوين
CORS_ORIGINS = "http://localhost:5173,http://localhost:3000"

# ============================================================
# 📝 إعدادات التسجيل
# ============================================================

# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL = "INFO"

# تنسيق السجل
LOG_FORMAT = "%(asctime)s | %(levelname)-8s | %(name)s | %(message)s"

# ملف السجل
LOG_FILE = "logs/app.log"

# الحد الأقصى لحجم الملف (بايت)
LOG_MAX_SIZE = 10485760  # 10MB

# عدد النسخ الاحتياطية
LOG_BACKUP_COUNT = 5

# ============================================================
# 🔒 إعدادات الأمان
# ============================================================

# خوارزمية JWT
JWT_ALGORITHM = "HS256"

# مدة صلاحية التوكن (دقائق)
JWT_EXPIRE_MINUTES = 30

# معدل الطلبات (عدد الطلبات في الفترة)
RATE_LIMIT_REQUESTS = 100
RATE_LIMIT_PERIOD = 60  # ثانية

# ============================================================
# 📄 إعدادات المستندات
# ============================================================

# الحد الأقصى لحجم الملف (بايت)
MAX_FILE_SIZE = 10485760  # 10MB

# الامتدادات المسموحة
ALLOWED_EXTENSIONS = ".txt,.docx,.pdf"

# ============================================================
# 🧪 إعدادات الاختبار
# ============================================================

# وضع الاختبار (True/False)
TESTING = False
TEST_DATABASE_URL = "sqlite:///./test.db"
